{
  "name": "devscope",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Developer Intelligence Analyzer — Transform raw GitHub data into actionable developer insights",
  "author": "DevScope Team",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "npm run build --workspace=apps/frontend",
    "build:backend": "npm run build --workspace=apps/backend",
    "build": "npm run build:backend && npm run build:frontend",
    "lint": "npm run lint --workspaces --if-present",
    "db:migrate": "npm run db:migrate --workspace=apps/backend",
    "db:push": "npm run db:push --workspace=apps/backend",
    "db:studio": "npm run db:studio --workspace=apps/backend",
    "db:seed": "npm run db:seed --workspace=apps/backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
